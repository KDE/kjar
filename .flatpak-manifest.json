{
  "id": "org.kde.kjar",
  "runtime": "org.kde.Platform",
  "runtime-version": "6.10",
  "sdk": "org.kde.Sdk",
  "command": "kjarapp",

  "sdk-extensions": [
    "org.freedesktop.Sdk.Extension.openjdk25"
  ],

  "finish-args": [
    "--share=ipc",
    "--socket=wayland",
    "--socket=x11",
    "--device=dri",
    "--talk-name=org.freedesktop.Flatpak",
    "--talk-name=org.freedesktop.Notifications",
    "--filesystem=home",
    "--env=JAVA_HOME=/app/jdk",
    "--env=PATH=/app/bin:/app/jdk/bin:/usr/bin"
  ],

  "modules": [
    {
      "name": "openjdk",
      "buildsystem": "simple",
      "build-commands": [
        "/usr/lib/sdk/openjdk25/installjdk.sh"
      ]
    },
    {
      "name": "entrypoint",
      "buildsystem": "cmake",
      "builddir": true,
      "sources": [
        {
          "type": "dir",
          "path": "."
        }
      ]
    },
    {
      "name": "desktop-file",
      "buildsystem": "simple",
      "build-commands": [
        "install -Dm644 org.kde.kjar.desktop /app/share/applications/org.kde.kjar.desktop"
      ],
      "sources": [
        {
          "type": "file",
          "path": "org.kde.kjar.desktop"
        }
      ]
    },
    {
      "name": "appstream",
      "buildsystem": "simple",
      "build-commands": [
        "install -Dm644 org.kde.kjar.metainfo.xml /app/share/metainfo/org.kde.kjar.metainfo.xml"
      ],
      "sources": [
        {
          "type": "file",
          "path": "org.kde.kjar.metainfo.xml"
        }
      ]
    }
  ]
}
