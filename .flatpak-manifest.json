{
  "id": "org.kde.kjar",
  "runtime": "org.kde.Platform",
  "runtime-version": "6.10",
  "sdk": "org.kde.Sdk",
  "command": "kjarapp",

  "sdk-extensions": [
    "org.freedesktop.Sdk.Extension.openjdk25"
  ],

  "finish-args": [
    "--share=ipc",
    "--socket=wayland",
    "--socket=x11",
    "--device=dri",
    "--talk-name=org.freedesktop.Flatpak",
    "--talk-name=org.freedesktop.Notifications",
    "--filesystem=home",
    "--env=JAVA_HOME=/app/jdk",
    "--env=PATH=/app/bin:/app/jdk/bin:/usr/bin"
  ],

  "modules": [
    {
      "name": "openjdk",
      "buildsystem": "simple",
      "build-commands": [
        "/usr/lib/sdk/openjdk25/installjdk.sh"
      ]
    },
    {
      "name": "openjfx",
      "buildsystem": "simple",
      "build-commands": [
        "install -d /app/share/javafx",
        "cp lib/*.jar /app/share/javafx/",
        "cp lib/*.so  /app/share/javafx/"
      ],
      "sources": [
        {
          "type": "archive",
          "url": "https://download2.gluonhq.com/openjfx/25/openjfx-25_linux-x64_bin-sdk.zip",
          "sha256": "a72157506746f03de493171313ec93425f1ec1b5cb4b446eee9a568ff484af4e",
          "dest": "."
        }
      ]
    },
    {
      "name": "entrypoint",
      "buildsystem": "cmake",
      "builddir": true,
      "sources": [
        {
          "type": "dir",
          "path": "."
        }
      ]
    },
    {
      "name": "desktop-file",
      "buildsystem": "simple",
      "build-commands": [
        "install -Dm644 org.kde.kjar.desktop /app/share/applications/org.kde.kjar.desktop"
      ],
      "sources": [
        {
          "type": "file",
          "path": "org.kde.kjar.desktop"
        }
      ]
    },
    {
      "name": "appstream",
      "buildsystem": "simple",
      "build-commands": [
        "install -Dm644 org.kde.kjar.metainfo.xml /app/share/metainfo/org.kde.kjar.metainfo.xml"
      ],
      "sources": [
        {
          "type": "file",
          "path": "org.kde.kjar.metainfo.xml"
        }
      ]
    }
  ]
}
